<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/card_bg"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/imgRequestAvatar"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:padding="10dp"
            android:src="@drawable/ic_person"
            android:background="@drawable/icon_container_bg"
            android:layout_marginEnd="12dp"/>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRequestName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvRequestUniversity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/muted"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvRequestScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/lime"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btnAccept"
                android:layout_width="80dp"
                android:layout_height="34dp"
                android:text="Accept"
                android:textSize="11sp"
                android:textColor="@color/dark_bg"
                android:textStyle="bold"
                android:background="@drawable/btn_lime"
                android:layout_marginBottom="6dp"/>

            <Button
                android:id="@+id/btnDecline"
                android:layout_width="80dp"
                android:layout_height="34dp"
                android:text="Decline"
                android:textSize="11sp"
                android:textColor="@color/muted"
                android:backgroundTint="@color/card_bg"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
