<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Avatar icon -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_person"
            android:padding="16dp"
            android:background="@drawable/icon_container_bg"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tvProfileName"
            android:text="Student"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvProfileUniversity"
            android:text="University"
            android:textSize="13sp"
            android:textColor="@color/muted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <ImageView android:src="@drawable/ic_score"
                    android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvConsistency" android:text="0%"
                    android:textSize="18sp" android:textStyle="bold"
                    android:textColor="@color/lime"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Score" android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:gravity="center"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp">
                <ImageView android:src="@drawable/ic_streak"
                    android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvProfileStreak" android:text="0"
                    android:textSize="18sp" android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Streak" android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:gravity="center"
                android:layout_marginStart="6dp">
                <ImageView android:src="@drawable/ic_trophy"
                    android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvBadges" android:text="0"
                    android:textSize="18sp" android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Badges" android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Sign Out Button -->
        <Button
            android:id="@+id/btnSignOut"
            android:text="Sign Out"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:backgroundTint="@color/card_bg"
            android:layout_width="match_parent"
            android:layout_height="52dp"/>

    </LinearLayout>
</ScrollView>
