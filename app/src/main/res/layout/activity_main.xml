<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Top spacing -->
        <View android:layout_width="0dp" android:layout_height="60dp"/>

        <!-- Logo -->
        <TextView
            android:text="HabitU"
            android:textSize="56sp"
            android:textStyle="bold"
            android:textColor="@color/lime"
            android:fontFamily="sans-serif-black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <!-- Tagline -->
        <TextView
            android:text="Build Habits. Find Your People."
            android:textSize="15sp"
            android:textColor="@color/muted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- Green line under tagline -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:background="@color/lime"
            android:layout_marginBottom="56dp"/>

        <!-- Welcome label -->
        <TextView
            android:text="Welcome back"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:text="Sign in to continue your streak"
            android:textSize="13sp"
            android:textColor="@color/muted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"/>

        <!-- Email label -->
        <TextView
            android:text="Email"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/lime"
            android:letterSpacing="0.08"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <!-- Email input -->
        <EditText
            android:id="@+id/etEmail"
            android:hint="your@email.com"
            android:inputType="textEmailAddress"
            android:background="@drawable/input_bg"
            android:textColor="@color/white"
            android:textColorHint="@color/muted"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <!-- Password label -->
        <TextView
            android:text="Password"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/lime"
            android:letterSpacing="0.08"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <!-- Password input -->
        <EditText
            android:id="@+id/etPassword"
            android:hint="Enter your password"
            android:inputType="textPassword"
            android:background="@drawable/input_bg"
            android:textColor="@color/white"
            android:textColorHint="@color/muted"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"/>

        <!-- Login button -->
        <Button
            android:id="@+id/btnLogin"
            android:text="Sign In"
            android:textColor="@color/dark_bg"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/btn_lime"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"/>

        <!-- Register link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:text="Don't have an account?  "
                android:textSize="14sp"
                android:textColor="@color/muted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvRegister"
                android:text="Sign up"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/lime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="40dp"/>

        <!-- Copyright -->
        <TextView
            android:text="© 2026 Ntshovelo Mhaleni"
            android:textSize="11sp"
            android:textColor="@color/muted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>