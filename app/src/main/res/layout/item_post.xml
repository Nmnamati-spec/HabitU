<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/card_bg"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Post image -->
        <ImageView
            android:id="@+id/imgPost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:background="@color/mid_bg"
            android:visibility="gone"/>

        <!-- Video post thumbnail with play button -->
        <FrameLayout
            android:id="@+id/frameVideoPost"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@color/mid_bg"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_play"
                android:alpha="0.75"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="8dp"
                android:text="VIDEO"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/lime"
                android:background="@drawable/tag_bg"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"/>

        </FrameLayout>

        <!-- No image: habit icon placeholder -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/mid_bg"
            android:visibility="gone"
            android:id="@+id/frameHabitIcon">

            <ImageView
                android:id="@+id/imgHabitIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:padding="8dp"
                android:background="@drawable/icon_container_bg"/>

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Habit tag -->
            <TextView
                android:id="@+id/tvHabitTag"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/lime"
                android:background="@drawable/tag_bg"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"/>

            <!-- Discover badge -->
            <TextView
                android:id="@+id/tvDiscoverBadge"
                android:text="Discover"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#FF6B35"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"/>

            <!-- Caption -->
            <TextView
                android:id="@+id/tvCaption"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:lineSpacingExtra="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <!-- User + actions row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPostUser"
                    android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <!-- Like button -->
                <LinearLayout
                    android:id="@+id/layoutLike"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/scale_press"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/imgLike"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_heart_outline"/>

                    <TextView
                        android:id="@+id/tvLikeCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/muted"
                        android:layout_marginStart="4dp"
                        android:text="0"/>

                </LinearLayout>

                <!-- Comment button -->
                <LinearLayout
                    android:id="@+id/layoutComment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/scale_press"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/imgComment"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_comment"/>

                    <TextView
                        android:id="@+id/tvCommentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/muted"
                        android:layout_marginStart="4dp"
                        android:text="0"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Comment preview -->
            <LinearLayout
                android:id="@+id/layoutCommentPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/comment_preview_bg"
                android:foreground="?attr/selectableItemBackground"
                android:padding="8dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvCommentPreview"
                    android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvViewAll"
                    android:text="View →"
                    android:textSize="10sp"
                    android:textColor="@color/lime"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
