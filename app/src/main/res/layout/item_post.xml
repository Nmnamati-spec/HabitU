<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/card_bg"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Post image -->
        <ImageView
            android:id="@+id/imgPost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:background="@color/mid_bg"
            android:visibility="gone"/>

        <!-- No image placeholder -->
        <TextView
            android:id="@+id/tvNoImageEmoji"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="center"
            android:textSize="40sp"
            android:background="@color/mid_bg"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Habit tag -->
            <TextView
                android:id="@+id/tvHabitTag"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/lime"
                android:background="@drawable/tag_bg"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"/>

            <!-- Discover badge -->
            <TextView
                android:id="@+id/tvDiscoverBadge"
                android:text="✨ Discover"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#FF6B35"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"/>

            <!-- Caption -->
            <TextView
                android:id="@+id/tvCaption"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:lineSpacingExtra="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <!-- User + actions row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPostUser"
                    android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/btnLike"
                    android:text="🤍 0"
                    android:textSize="11sp"
                    android:textColor="@color/muted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btnComment"
                    android:text="💬 0"
                    android:textSize="11sp"
                    android:textColor="@color/muted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- Comment preview -->
            <LinearLayout
                android:id="@+id/layoutCommentPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/comment_preview_bg"
                android:padding="8dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvCommentPreview"
                    android:textSize="10sp"
                    android:textColor="@color/muted"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvViewAll"
                    android:text="View →"
                    android:textSize="10sp"
                    android:textColor="@color/lime"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>